
{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A contact request or message from a potential client or employer.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the person reaching out."
        },
        "company": {
          "type": "string",
          "description": "The company name provided."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The contact email address."
        },
        "message": {
          "type": "string",
          "description": "The detailed message or inquiry."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the message was sent."
        }
      },
      "required": [
        "name",
        "email",
        "message",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of contact form submissions."
    }
  }
}
